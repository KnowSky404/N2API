# Server
N2API_HOST=0.0.0.0
N2API_PORT=3000
N2API_PUBLIC_URL=http://localhost:3000
# Comma-separated CIDRs for reverse proxies that connect directly to N2API.
# Empty trusts no forwarding headers. Never use 0.0.0.0/0 or ::/0.
N2API_TRUSTED_PROXY_CIDRS=
# Optional in-process gateway concurrency guard. 0 disables the limit.
N2API_GATEWAY_MAX_CONCURRENT_REQUESTS=0
# Optional per-provider-account concurrency guard. 0 disables the limit.
N2API_GATEWAY_MAX_CONCURRENT_REQUESTS_PER_ACCOUNT=0
# Optional per-API-key concurrency guard. 0 disables the limit.
N2API_GATEWAY_MAX_CONCURRENT_REQUESTS_PER_KEY=0
# Optional per-API-key request rate limit per minute. 0 disables the limit.
N2API_GATEWAY_REQUESTS_PER_MINUTE_PER_KEY=0
# Optional per-API-key observed token rate limit per minute. 0 disables the limit.
N2API_GATEWAY_TOKENS_PER_MINUTE_PER_KEY=0
# System event retention. 0 disables cleanup; enabled values must be 30-3650 days.
N2API_SYSTEM_EVENT_RETENTION_DAYS=365
# API upstream accounts require HTTPS by default. Set true only for trusted local/private HTTP upstreams.
N2API_ALLOW_HTTP_API_UPSTREAMS=false
# Provider account auto tests are disabled by default to avoid surprise upstream traffic.
# These startup defaults seed Gateway Settings until the admin saves runtime settings.
N2API_PROVIDER_ACCOUNT_AUTO_TEST_ENABLED=false
N2API_PROVIDER_ACCOUNT_AUTO_TEST_INTERVAL_SECONDS=300

# PostgreSQL
POSTGRES_DB=n2api
POSTGRES_USER=n2api
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://n2api:change-me@postgres:5432/n2api?sslmode=disable

# Admin
N2API_ADMIN_USERNAME=admin
N2API_ADMIN_PASSWORD=change-me

# Secret material used for encrypting OAuth tokens at rest.
# Use a long random value in real deployments.
N2API_ENCRYPTION_SECRET=change-me-to-a-long-random-secret

# OpenAI/Codex OAuth.
# The default flow uses the Codex-compatible OpenAI OAuth client with PKCE.
# Leave these OAuth values blank unless you intentionally need endpoint/client overrides.
OPENAI_OAUTH_CLIENT_ID=
OPENAI_OAUTH_CLIENT_SECRET=
OPENAI_OAUTH_REDIRECT_URL=http://localhost:1455/auth/callback
OPENAI_OAUTH_AUTH_URL=
OPENAI_OAUTH_TOKEN_URL=
OPENAI_API_BASE_URL=https://api.openai.com
