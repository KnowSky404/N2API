# Server
N2API_HOST=0.0.0.0
N2API_PORT=3000
N2API_PUBLIC_URL=http://localhost:3000
# Required only by release Compose. Replace YYYYMMDDNN with an immutable CalVer
# tag from the matching checkout, or use a complete ghcr.io digest reference.
N2API_IMAGE=ghcr.io/knowsky404/n2api:YYYYMMDDNN
# Comma-separated startup risks accepted by the operator. Valid values:
# public-http, public-bind, database-plaintext. Never use an "all" value.
# Local Compose supplies its development risks when this remains empty.
N2API_ACCEPT_RISKS=
# Release Compose publishes one address family on IPv4 loopback by default.
# Use a specific LAN address, 0.0.0.0, ::1, or :: only with matching firewall rules.
# Docker-only and dual-stack overrides are documented under Host Binding Modes in docs/manual.md.
N2API_BIND_ADDRESS=127.0.0.1
# Comma-separated CIDRs for reverse proxies that connect directly to N2API.
# Empty trusts no forwarding headers. Never use 0.0.0.0/0 or ::/0.
N2API_TRUSTED_PROXY_CIDRS=
# In-memory administrator login throttle. Set false only for rollback/debugging.
N2API_ADMIN_LOGIN_THROTTLE_ENABLED=true
# Failed attempts per normalized IP or username before temporary denial begins (1-20).
N2API_ADMIN_LOGIN_THROTTLE_FAILURES=5
# Combined IP and username entry bound (128-16384).
N2API_ADMIN_LOGIN_THROTTLE_MAX_ENTRIES=4096
# Absolute administrator session lifetime in hours (1-8760).
N2API_ADMIN_SESSION_TTL_HOURS=168
# Optional in-process gateway concurrency guard. 0 disables the limit.
N2API_GATEWAY_MAX_CONCURRENT_REQUESTS=0
# Optional per-provider-account concurrency guard. 0 disables the limit.
N2API_GATEWAY_MAX_CONCURRENT_REQUESTS_PER_ACCOUNT=0
# Optional per-API-key concurrency guard. 0 disables the limit.
N2API_GATEWAY_MAX_CONCURRENT_REQUESTS_PER_KEY=0
# Optional per-API-key request rate limit per minute. 0 disables the limit.
N2API_GATEWAY_REQUESTS_PER_MINUTE_PER_KEY=0
# Optional per-API-key observed token rate limit per minute. 0 disables the limit.
N2API_GATEWAY_TOKENS_PER_MINUTE_PER_KEY=0
# System event retention. 0 disables cleanup; enabled values must be 30-3650 days.
N2API_SYSTEM_EVENT_RETENTION_DAYS=365
# Alert delivery is disabled by default to avoid outbound notification traffic after upgrades.
N2API_ALERT_DELIVERY_ENABLED=false
# Automatic Request Log cleanup is a separate startup gate and remains off after upgrades,
# even when Gateway Settings already contains a positive retention window.
N2API_REQUEST_LOG_RETENTION_RUNNER_ENABLED=false
# Automatic cleanup runs immediately at startup, then at this bounded interval (300-604800 seconds).
N2API_REQUEST_LOG_RETENTION_INTERVAL_SECONDS=86400
# Each Request Log cleanup transaction deletes at most this many rows (100-10000).
N2API_REQUEST_LOG_RETENTION_BATCH_SIZE=1000
# Maximum rows written by one streaming Request Log CSV or JSONL export (1000-1000000).
N2API_REQUEST_LOG_EXPORT_MAX_ROWS=100000
# Maximum duration of one streaming Request Log export in seconds (5-300).
N2API_REQUEST_LOG_EXPORT_TIMEOUT_SECONDS=60
# API upstream accounts require HTTPS by default. Set true only for trusted local/private HTTP upstreams.
N2API_ALLOW_HTTP_API_UPSTREAMS=false
# Provider account auto tests are disabled by default to avoid surprise upstream traffic.
# These startup defaults seed Gateway Settings until the admin saves runtime settings.
N2API_PROVIDER_ACCOUNT_AUTO_TEST_ENABLED=false
N2API_PROVIDER_ACCOUNT_AUTO_TEST_INTERVAL_SECONDS=300

# PostgreSQL
POSTGRES_DB=n2api
POSTGRES_USER=n2api
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://n2api:change-me@postgres:5432/n2api?sslmode=disable
# Local Compose backup interval in seconds (300-604800). Default: every 6 hours.
N2API_BACKUP_INTERVAL_SECONDS=21600
# Local Compose backup retention in days (1-3650).
N2API_BACKUP_RETENTION_DAYS=7
# Host operator group that may list and read local backup archives (`id -g`).
N2API_BACKUP_GID=1000

# Admin
N2API_ADMIN_USERNAME=admin
N2API_ADMIN_PASSWORD=change-me

# Secret material used for encrypting OAuth tokens at rest.
# Use a long random value in real deployments.
N2API_ENCRYPTION_SECRET=change-me-to-a-long-random-secret
# Stable non-secret identifier written into new ciphertext envelopes.
N2API_ENCRYPTION_KEY_ID=default
# Ordered JSON array used only during an explicit rotation window.
# Schema: [{"id":"previous-YYYYMM","secret":"..."}]
N2API_ENCRYPTION_PREVIOUS_KEYS=[]

# OpenAI/Codex OAuth.
# The default flow uses the Codex-compatible OpenAI OAuth client with PKCE.
# Leave these OAuth values blank unless you intentionally need endpoint/client overrides.
OPENAI_OAUTH_CLIENT_ID=
OPENAI_OAUTH_CLIENT_SECRET=
OPENAI_OAUTH_REDIRECT_URL=http://localhost:1455/auth/callback
OPENAI_OAUTH_AUTH_URL=
OPENAI_OAUTH_TOKEN_URL=
OPENAI_API_BASE_URL=https://api.openai.com
