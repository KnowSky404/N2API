FROM golang:1.26-alpine AS mock-openai-builder
WORKDIR /src/backend
COPY backend/go.mod backend/go.sum ./
RUN go mod download
COPY backend/ ./
RUN CGO_ENABLED=0 go build -trimpath -o /out/mock-openai ./cmd/mock-openai

FROM alpine:3.23
RUN apk add --no-cache curl
WORKDIR /app
COPY --from=mock-openai-builder /out/mock-openai /app/mock-openai
USER 65532:65532
EXPOSE 8080
ENTRYPOINT ["/app/mock-openai"]
