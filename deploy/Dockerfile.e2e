FROM golang:1.26.4-alpine3.23@sha256:18b460dd17542c2ba43299a633cf6ebfc1115101509531471d7cfce1019af083 AS e2e-go-base
WORKDIR /src/backend
COPY backend/go.mod backend/go.sum ./
RUN go mod download
COPY backend/ ./

FROM e2e-go-base AS mock-openai-builder
RUN CGO_ENABLED=0 go build -trimpath -o /out/mock-openai ./cmd/mock-openai

FROM alpine:3.23.5@sha256:fd791d74b68913cbb027c6546007b3f0d3bc45125f797758156952bc2d6daf40 AS mock-openai
RUN apk add --no-cache curl
WORKDIR /app
COPY --from=mock-openai-builder /out/mock-openai /app/mock-openai
USER 65532:65532
EXPOSE 8080
ENTRYPOINT ["/app/mock-openai"]

FROM e2e-go-base AS gateway-e2e-builder
RUN CGO_ENABLED=0 go test -c -o /out/gateway-e2e ./e2e

FROM alpine:3.23.5@sha256:fd791d74b68913cbb027c6546007b3f0d3bc45125f797758156952bc2d6daf40 AS gateway-e2e
WORKDIR /app
COPY --from=gateway-e2e-builder /out/gateway-e2e /app/gateway-e2e
USER 65532:65532
ENTRYPOINT ["/app/gateway-e2e", "-test.v", "-test.timeout=3m"]

FROM oven/bun:1.3.14-alpine@sha256:5acc90a93e91ff07bf72aa90a7c9f0fa189765aec90b47bdbf2152d2196383c0 AS contracts-javascript
WORKDIR /app
COPY tests/contracts/javascript/package.json tests/contracts/javascript/bun.lock ./
RUN bun install --frozen-lockfile --production
COPY tests/contracts/javascript/openai.test.ts ./
USER bun
ENTRYPOINT ["bun", "test", "openai.test.ts"]

FROM ghcr.io/astral-sh/uv:0.11.30@sha256:93b61e21202b1dab861092748e46bbd6e0e41dd84f59b9174efd2353186e1b47 AS uv-bin

FROM python:3.12.13-slim-bookworm@sha256:d50fb7611f86d04a3b0471b46d7557818d88983fc3136726336b2a4c657aa30b AS contracts-python
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_PYTHON_DOWNLOADS=never
WORKDIR /app
COPY --from=uv-bin /uv /uvx /bin/
COPY tests/contracts/python/pyproject.toml tests/contracts/python/uv.lock tests/contracts/python/.python-version ./
RUN uv sync --locked --no-dev --no-install-project
COPY tests/contracts/python/test_openai.py ./
USER 65532:65532
ENTRYPOINT ["/app/.venv/bin/python", "-m", "unittest", "-v", "test_openai.py"]
